<div class="w-full mb-12 xl:mb-0 px-4 mx-auto">
  <div class="relative flex flex-col min-w-0 break-words bg-white w-full mb-6 shadow-lg rounded bg-slate-100">
    <div class="rounded-t mb-0 px-4 py-3 border-0">
      <div class="flex flex-wrap items-center">
        <div class="relative w-full px-4 max-w-full flex-grow flex-1">
          <h1 class="font-semibold text-blueGray-700 text-4xl">Webhook deliveries</h1>
        </div>
      </div>
    </div>

    <%= render(WebhookDeliveries::TableComponent.new(webhook_deliveries: @webhook_deliveries)) do |component| %>
      <% component.with_headers do %>
        <th class="cellheader-condensed">Id</th>
        <th class="cellheader-condensed">Status</th>
        <th class="cellheader-condensed">Url</th>
        <th class="cellheader-condensed">Attempts</th>
        <th class="cellheader-condensed">Response code</th>
        <th class="cellheader-condensed">Response</th>
        <th class="cellheader-condensed">Payload</th>
      <% end %>

      <% @webhook_deliveries.each do |delivery| %>
        <% component.with_row do %>
          <%= render(WebhookDeliveries::WebhookDeliveryRowComponent.new(webhook_delivery: delivery)) %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
