<%= render AttributesComponent.new do |c| %>
  <% c.with_row(grid_cols: 4) do |row| %>
    <% row.with_value(title: "Status", size: :info) do %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-1">
        <div class="col-span-1">
          <%= render ResponseCodeBadgeComponent.new(response_code: webhook_delivery.last_delivery_attempt&.response_code) %>
        </div>
      </div>
    <% end %>

    <% row.with_value(title: "URL", size: :detail) do %>
      <%= webhook_delivery.url %>
    <% end %>

    <% row.with_value(title: "Created", size: :info) do %>
      <%= time_ago_in_words(webhook_delivery.created_at) %> ago
    <% end %>
  <% end %>

  <% c.with_row(grid_cols: 4) do |row| %>
    <% row.with_value(title: "Payload", size: :detail) do %>
      <pre class="whitespace-pre-wrap break-all font-mono overflow-x-auto max-h-80"><%= webhook_delivery.payload %></pre>
    <% end %>

    <%= row.with_value(title: "Last response", size: :detail) do %>
      <pre class="whitespace-pre-wrap break-all font-mono overflow-x-auto max-h-80"><%= webhook_delivery.last_delivery_attempt&.response %></pre>
    <% end %>
  <% end %>
<% end %>
