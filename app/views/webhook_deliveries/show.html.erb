<h1 class="text-4xl font-semibold mb-8">Webhook delivery <%= @webhook_delivery.id %></h1>

<div class="mb-8">
  <dl>
    <div class="flex px-6 py-4 border-b border-gray-200">
      <dt class="w-48 text-sm font-medium text-gray-500 shrink-0">ID</dt>
      <dd class="text-sm text-gray-900"><%= @webhook_delivery.id %></dd>
    </div>

    <div class="flex px-6 py-4 border-b border-gray-200">
      <dt class="w-48 text-sm font-medium text-gray-500 shrink-0">Status</dt>
      <dd><%= render StatusBadgeComponent.new(status: @webhook_delivery.status) %></dd>
    </div>

    <div class="flex px-6 py-4 border-b border-gray-200">
      <dt class="w-48 text-sm font-medium text-gray-500 shrink-0">URL</dt>
      <dd class="text-sm text-gray-900 break-all"><%= @webhook_delivery.url %></dd>
    </div>

    <div class="flex px-6 py-4 border-b border-gray-200">
      <dt class="w-48 text-sm font-medium text-gray-500 shrink-0">Payload</dt>
      <dd class="text-sm font-mono text-gray-900 overflow-x-auto">
        <pre class="whitespace-pre-wrap break-all"><%= @webhook_delivery.payload %></pre>
      </dd>
    </div>

    <div class="flex px-6 py-4 border-b border-gray-200">
      <dt class="w-48 text-sm font-medium text-gray-500 shrink-0">Created at</dt>
      <dd class="text-sm text-gray-900" title="<%= @webhook_delivery.created_at %>"><%= time_ago_in_words(@webhook_delivery.created_at) %> ago</dd>
    </div>

    <div class="flex px-6 py-4 border-b border-gray-200">
      <dt class="w-48 text-sm font-medium text-gray-500 shrink-0">Last response code</dt>
      <dd class="text-sm font-mono text-gray-900"><%= @webhook_delivery.last_response_code %></dd>
    </div>

    <div class="flex px-6 py-4">
      <dt class="w-48 text-sm font-medium text-gray-500 shrink-0">Last response</dt>
      <dd class="text-sm font-mono text-gray-900 overflow-x-auto">
        <pre class="whitespace-pre-wrap break-all"><%= @webhook_delivery.last_response %></pre>
      </dd>
    </div>
  </dl>
</div>

<h2 class="text-2xl font-semibold mb-4">Delivery attempts</h2>

<div class="table-card">
  <%= render TableComponent.new(class_names: "min-w-full divide-y divide-gray-200", tbody_class_names: "divide-y divide-gray-200") do |table| %>
    <% table.with_header(class_names: "px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") { "Status" } %>
    <% table.with_header(class_names: "px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") { "Created at" } %>
    <% table.with_header(class_names: "px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") { "Response code" } %>

    <% @webhook_delivery_attempts.each do |attempt| %>
      <% table.with_row(class_names: "bg-white even:bg-gray-50") do |row| %>
        <% row.with_cell(class_names: "px-6 py-4 whitespace-nowrap") { render StatusBadgeComponent.new(status: attempt.status) } %>
        <% row.with_cell(class_names: "px-6 py-4 whitespace-nowrap", html: { title: attempt.created_at.to_s }) { time_ago_in_words(attempt.created_at) + " ago" } %>
        <% row.with_cell(class_names: "px-6 py-4 whitespace-nowrap font-mono") { attempt.response_code.to_s } %>
      <% end %>
    <% end %>
  <% end %>
</div>
