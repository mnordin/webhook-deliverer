<%= turbo_stream_from @webhook_delivery.identity %>

<h1 class="text-4xl font-semibold mb-8">Webhook delivery <%= @webhook_delivery.id %></h1>

<div class="mb-8">
  <%= turbo_frame_tag dom_id(@webhook_delivery, :attributes) do %>
    <%= render partial: "attributes", locals: {webhook_delivery: @webhook_delivery} %>
  <% end %>
</div>

<h2 class="text-2xl font-semibold mb-4">Delivery attempts</h2>

<div class="table-card">
  <%= render TableComponent.new(
    class_names: "min-w-full divide-y divide-gray-200",
    tbody_class_names: "divide-y divide-gray-200",
    tbody_html: {id: "webhook_delivery_attempts"}
  ) do |table| %>
    <% table.with_header(class_names: "px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") { "Status" } %>
    <% table.with_header(class_names: "px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") { "Created at" } %>
    <% table.with_header(class_names: "px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") { "Response code" } %>

    <% @webhook_delivery_attempts.each do |attempt| %>
      <% table.with_row(class_names: "bg-white even:bg-gray-50") do |row| %>
        <% row.with_cell(class_names: "px-6 py-4 whitespace-nowrap") { render ResponseCodeBadgeComponent.new(response_code: attempt.response_code) } %>
        <% row.with_cell(class_names: "px-6 py-4 whitespace-nowrap", html: { title: attempt.created_at.to_s }) { time_ago_in_words(attempt.created_at) + " ago" } %>
        <% row.with_cell(class_names: "px-6 py-4 whitespace-nowrap font-mono") { attempt.response_code.to_s } %>
      <% end %>
    <% end %>
  <% end %>
</div>
