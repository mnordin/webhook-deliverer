<%= tag.table(class: class_names(css_classes).presence, **html) do %>
  <thead>
    <tr>
      <% headers.each do |header| %>
        <%= header %>
      <% end %>
    </tr>
  </thead>
  <%= tag.tbody(class: class_names(tbody_css_classes).presence, **tbody_html) do %>
    <% rows.each do |row| %>
      <%= row %>
    <% end %>
  <% end %>
<% end %>
