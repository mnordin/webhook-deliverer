<%= tag.table(class: class_names(css_classes).presence, **html) do %>
  <thead>
    <tr>
      <% headers.each do |header| %>
        <th class="cellheader-condensed"><%= header %></th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% rows.each do |row| %>
      <%= row %>
    <% end %>
  </tbody>
<% end %>
